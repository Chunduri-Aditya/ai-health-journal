# AI Health Journal — local configuration template.
# Copied to .env on first run of ./start.sh. Edit .env freely; it is gitignored.

# ── Model selection ──────────────────────────────────────────────
# "balanced" auto-picks a stack based on machine RAM and installed Ollama models.
MODEL_SELECTION_STRATEGY=balanced
MODEL_MACHINE_TIER_OVERRIDE=auto

# Optional explicit overrides (uncomment to force specific models):
# GENERATOR_MODEL=qwen3:8b
# FALLBACK_MODEL=qwen3:8b
# VERIFIER_MODEL=qwen3:8b
# PROMPT_MODEL=gemma3:4b

# ── Feature flags ────────────────────────────────────────────────
QUALITY_MODE_DEFAULT=false
RETRIEVAL_ENABLED=true
GROUNDEDNESS_THRESHOLD=0.75

# ── Retrieval backend (only used when RETRIEVAL_ENABLED=true) ────
# none / chroma / pinecone
# chroma (local, default) ships in the core install; no extra step.
# First query downloads the default MiniLM embedder (~80MB) from HuggingFace;
# after that it runs fully offline from ./storage/chroma.
VECTOR_BACKEND=chroma
ALLOW_CLOUD_VECTORSTORE=false
# CHROMA_PERSIST_DIR=./storage/chroma

# ── Namespace isolation (see docs/upgrades/01-retrieval-grounding.md) ─
# session / user / fixed
RAG_NAMESPACE_MODE=session
RAG_NAMESPACE_FIXED=ai-health-journal

# ── Privacy ──────────────────────────────────────────────────────
PRIVACY_MODE=balanced
LOCAL_CACHE_MAX_ITEMS=2000

# ── Voice transcription (requires openai-whisper) ────────────────
WHISPER_MODEL=base
WHISPER_MAX_AUDIO_BYTES=15728640

# ── Web session ──────────────────────────────────────────────────
# SECRET_KEY is regenerated every boot unless you pin it here.
# SECRET_KEY=change-me-to-a-long-random-string
